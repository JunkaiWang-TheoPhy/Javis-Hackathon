#!/usr/bin/env bash
set -euo pipefail

script_dir="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
. "$script_dir/mac-camera-common.sh"

ensure_cache_dir
printf '%s' "$$" > "$loop_pid_path"

cleanup() {
  rm -f "$loop_pid_path"
}
trap cleanup EXIT

while true; do
  if ! "$script_dir/mac-camera-shot" >>"$loop_log_path" 2>&1; then
    echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] mac-camera-shot failed" >>"$loop_log_path"
    sleep "$mac_camera_interval_sec"
    continue
  fi

  if ! "$script_dir/mac-camera-emit-event" >>"$loop_log_path" 2>&1; then
    echo "[$(date -u +"%Y-%m-%dT%H:%M:%SZ")] mac-camera-emit-event failed" >>"$loop_log_path"
  fi

  sleep "$mac_camera_interval_sec"
done
